---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

// ─── DATA ────────────────────────────────────────────────────────────────────

type Author = { name: string; highlight?: boolean };

type JournalPub = {
  year: string;
  title: string;
  authors: Author[];
  venue?: string;
  url?: string;
};

type ConferencePub = {
  year: string;
  title: string;
  authors: Author[];
  award?: string;
  conference?: string;
  type?: string;
  url?: string;
};

const journalPubs: JournalPub[] = [
  {
    year: '2020',
    title: 'Dosimetric and Clinical Advantages of Adapting the DIBH Technique to Hybrid Solitary Dynamic Portal Radiotherapy for Left-sided Chest-wall plus Regional Nodal Irradiation',
    authors: [
      { name: 'Mohamathu Rafic' },
      { name: 'Patricia Solomon' },
      { name: 'Timothy Peace Balasingh Santosh' },
      { name: 'Sujith Christopher', highlight: true },
      { name: 'Selva Mani' },
      { name: 'Paul Ravindran' },
    ],
    venue: 'Medical Dosimetry · Vol. 45, Issue 3, pp. 256–263',
  },
  {
    year: '2020',
    title: 'A new strategy for craniospinal axis localization and adaptive dosimetric verification using cone beam CT',
    authors: [
      { name: 'Mohamathu Rafic' },
      { name: 'Sujith Christopher', highlight: true },
      { name: 'Rajesh Balakrishnan' },
      { name: 'Ebenezer Suman Babu' },
      { name: 'Timothy Peace Balasingh Santosh' },
    ],
    venue: 'Reports of Practical Oncology & Radiotherapy · 25(2), 282–292',
  },
  {
    year: '2019',
    title: 'Escalation of optical transmittance and determination of diffusion co-efficient in low-bloom strength gelatin-based Fricke gel dosimeters',
    authors: [
      { name: 'Ebenezer Suman Babu' },
      { name: 'Timothy Peace Balasingh Santosh' },
      { name: 'Winfred MR' },
      { name: 'Rafic KM' },
      { name: 'Sujith Christopher', highlight: true },
      { name: 'Ravindran BP' },
    ],
    venue: 'Radiation Physics and Chemistry · 156, 300–306',
  },
  {
    year: '2019',
    title: 'A new strategy to determine off-axis dosimetric leaf gap using optically stimulated luminescence dosimeters and an electronic portal imaging device',
    authors: [
      { name: 'Divyalakshmi' },
      { name: 'Timothy Peace Balasingh Santosh' },
      { name: 'KM Rafic' },
      { name: 'Amalan Sebastin' },
      { name: 'Jose Solomon' },
      { name: 'Sujith Christopher', highlight: true },
    ],
  },
  {
    year: '2018',
    title: 'Planar and Volumetric Imaging Dosimetry for Longitudinal Projection Extended Cone Beam CT based Adaptive Radiotherapy',
    authors: [
      { name: 'K Mohamathu Rafic' },
      { name: 'Ebenezer Suman Babu' },
      { name: 'S Timothy Peace Balasingh' },
      { name: 'Sujith Christopher J', highlight: true },
      { name: 'Abel Juhan Thomas' },
      { name: 'B Paul Ravindran' },
    ],
  },
  {
    year: '2018',
    title: 'A survey on intelligence based biometric techniques for authentication applications',
    authors: [
      { name: 'Martin Sagayam' },
      { name: 'Felix Jacob' },
      { name: 'Sujith Christopher', highlight: true },
      { name: 'Santhosh A Immanuel' },
      { name: 'Vamsidhar Reddy' },
    ],
    venue: 'Lecture Notes in Computational Vision and Biomechanics (Vol. 25)',
  },
];

const conferencePubs: ConferencePub[] = [
  {
    year: '2022',
    title: 'Design and Development Of 3D Printed Paediatric Phantom for Evaluating the Accuracy of Deformable Image Registration Technique and Patient Specific QA',
    authors: [
      { name: 'Sujith Christopher', highlight: true },
      { name: 'Timothy Peace Balasingh Santosh' },
      { name: 'Rafiq KM' },
      { name: 'Kavin' },
    ],
    award: 'Best Paper Award',
    conference: 'Prof. T. N. B. NEDUNGADI Best Paper Award, TN & PY AMPICON 2022',
  },
  {
    year: '2022',
    title: 'Gamified upper limb therapy using an instrumented arm skateboard (ArmBo) and the YOLO framework',
    authors: [
      { name: 'Sujith Christopher J', highlight: true },
      { name: 'Samuel Elias' },
      { name: 'Prem Kumar' },
      { name: 'Sivakumar Balasubramanian' },
    ],
    conference: 'Annual Research Day 2022, CMC Vellore',
    type: 'Poster',
  },
  {
    year: '2022',
    title: 'Realtime feedback using an instrumented arm skateboard for upper-limb rehabilitation',
    authors: [
      { name: 'Sujith Christopher J', highlight: true },
      { name: 'Sivakumar Balasubramanian' },
    ],
    conference: 'Annual Research Day 2022, CMC Vellore',
    type: 'Poster',
  },
  {
    year: '2022',
    title: 'Investigation on sensor fusion-based feedback in arm-skateboard for upper-limb rehabilitation',
    authors: [
      { name: 'Sujith Christopher J', highlight: true },
      { name: 'Sivakumar Balasubramanian' },
    ],
    conference: 'Empower 2022, IIT-M',
    type: 'Poster',
  },
  {
    year: '2020',
    title: 'Dynamic HU mapping and deformable image registration algorithm for adaptive treatment planning and dose calculation using neural network',
    authors: [
      { name: 'Sujith Christopher J', highlight: true },
      { name: 'Timothy Peace Balasingh Santosh' },
      { name: 'Rafic KM' },
      { name: 'Paul Ravindran' },
    ],
    conference: 'Joint AAPM/COMP Virtual Meeting, 2020',
    type: 'E-Poster',
  },
  {
    year: '2019',
    title: 'Respiratory phantom for patient specific quality assurance of 4D gated radiation therapy',
    authors: [
      { name: 'Sujith Christopher', highlight: true },
      { name: 'Timothy Peace Balasingh Santosh' },
      { name: 'Paul Ravindran' },
    ],
  },
  {
    year: '2019',
    title: 'Wireless robotic phantom for quality assurance of 4D gated radiation therapy',
    authors: [
      { name: 'Sujith Christopher', highlight: true },
      { name: 'Paul Ravindran' },
    ],
    award: 'First Prize',
    conference: '9th Annual Research Day, CMC Vellore — First prize in Bioengineering category',
  },
];

const JOURNALS_INITIAL = 2;
const CONFERENCES_INITIAL = 3;

function formatAuthors(authors: Author[]): string {
  return authors
    .map(a =>
      a.highlight
        ? `<span class="text-gray-900 dark:text-white font-bold underline decoration-primary-500/50">${a.name}</span>`
        : a.name
    )
    .join(', ');
}

// ─── END DATA ─────────────────────────────────────────────────────────────────
---

<Layout
  title="Research & Publications - Sujith Christopher | Computer Vision & Biomedical Robotics"
  description="Explore Sujith Christopher's research in computer vision, AI, sensors, and biomedical robotics. Discover his publications, conference presentations, and contributions to bioengineering and neuro-rehabilitation technology at IIT Madras."
  keywords="Sujith Christopher research, computer vision research, biomedical robotics, AI research, sensors research, IIT Madras research, bioengineering publications, neuro-rehabilitation technology, research publications"
>
  <Header />

  <main>
    <!-- Page Header -->
    <section class="pt-24 pb-4">
      <div class="container-custom">
        <div class="max-w-3xl">
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-1">
            Research & Publications
          </h1>
          <p class="text-sm text-gray-500 dark:text-gray-400">
            Computer Vision · Biomedical Robotics · Neuro-Rehabilitation
          </p>
        </div>
      </div>
    </section>

    <!-- Journal Publications -->
    <section class="section-padding">
      <div class="container-custom">
        <div class="max-w-5xl mx-auto">
          <div class="flex flex-col md:flex-row md:items-end justify-between mb-6 gap-2 border-b border-gray-200 dark:border-gray-800 pb-4">
            <div>
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white">
                Journal Publications
              </h2>
              <p class="text-gray-500 dark:text-gray-400 text-sm mt-0.5">Peer Reviewed Articles ({journalPubs.length})</p>
            </div>
          </div>

          <div id="journal-publications" class="divide-y divide-gray-100 dark:divide-gray-800">
            {journalPubs.slice(0, JOURNALS_INITIAL).map(pub => (
              <div class="pub-row">
                <div class="flex items-baseline gap-4">
                  <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">{pub.year}</span>
                  <div>
                    <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">{pub.title}</p>
                    <p class="text-sm text-gray-600 dark:text-gray-400" set:html={formatAuthors(pub.authors)}></p>
                    {pub.venue && (
                      <p class="text-xs text-gray-500 dark:text-gray-500 italic mt-0.5">{pub.venue}</p>
                    )}
                  </div>
                </div>
              </div>
            ))}

            <div id="hidden-journals" class="hidden divide-y divide-gray-100 dark:divide-gray-800">
              {journalPubs.slice(JOURNALS_INITIAL).map(pub => (
                <div class="pub-row">
                  <div class="flex items-baseline gap-4">
                    <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">{pub.year}</span>
                    <div>
                      <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">{pub.title}</p>
                      <p class="text-sm text-gray-600 dark:text-gray-400" set:html={formatAuthors(pub.authors)}></p>
                      {pub.venue && (
                        <p class="text-xs text-gray-500 dark:text-gray-500 italic mt-0.5">{pub.venue}</p>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <!-- Show More Button -->
            <div class="pt-3">
              <button
                id="toggle-journals-btn"
                class="text-sm text-primary-600 dark:text-primary-400 hover:underline"
              >
                <span id="journals-btn-text">Show All Publications</span>
                <svg id="journals-chevron" class="w-4 h-4 ml-1 transition-transform duration-300 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Conference Publications & Awards -->
    <section class="section-padding bg-gray-50 dark:bg-gray-900/50">
      <div class="container-custom">
        <div class="max-w-5xl mx-auto">
          <div class="flex flex-col md:flex-row md:items-end justify-between mb-6 gap-2 border-b border-gray-200 dark:border-gray-800 pb-4">
            <div>
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white">
                Conferences & Awards
              </h2>
              <p class="text-gray-500 dark:text-gray-400 text-sm mt-0.5">Presentations & Recognitions ({conferencePubs.length})</p>
            </div>
          </div>

          <div id="conference-publications" class="divide-y divide-gray-100 dark:divide-gray-800">
            {conferencePubs.slice(0, CONFERENCES_INITIAL).map(pub => (
              <div class="pub-row">
                <div class="flex items-baseline gap-4">
                  <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">{pub.year}</span>
                  <div>
                    <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                      {pub.award && (
                        <span class="text-xs font-semibold text-amber-700 dark:text-amber-400 mr-1">{pub.award} —</span>
                      )}
                      {pub.title}
                    </p>
                    <p class="text-sm text-gray-600 dark:text-gray-400" set:html={formatAuthors(pub.authors)}></p>
                    {(pub.conference || pub.type) && (
                      <p class="text-xs text-gray-500 dark:text-gray-500 italic mt-0.5">
                        {pub.conference}{pub.type ? ` (${pub.type})` : ''}
                      </p>
                    )}
                  </div>
                </div>
              </div>
            ))}

            <div id="hidden-conferences" class="hidden divide-y divide-gray-100 dark:divide-gray-800">
              {conferencePubs.slice(CONFERENCES_INITIAL).map(pub => (
                <div class="pub-row">
                  <div class="flex items-baseline gap-4">
                    <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">{pub.year}</span>
                    <div>
                      <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                        {pub.award && (
                          <span class="text-xs font-semibold text-amber-700 dark:text-amber-400 mr-1">{pub.award} —</span>
                        )}
                        {pub.title}
                      </p>
                      <p class="text-sm text-gray-600 dark:text-gray-400" set:html={formatAuthors(pub.authors)}></p>
                      {(pub.conference || pub.type) && (
                        <p class="text-xs text-gray-500 dark:text-gray-500 italic mt-0.5">
                          {pub.conference}{pub.type ? ` (${pub.type})` : ''}
                        </p>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <!-- Show More Button -->
            <div class="pt-3">
              <button
                id="toggle-conferences-btn"
                class="text-sm text-primary-600 dark:text-primary-400 hover:underline"
              >
                <span id="conferences-btn-text">View All Conference Items</span>
                <svg id="conferences-chevron" class="w-4 h-4 ml-1 transition-transform duration-300 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Research Domains -->
    <section class="section-padding">
      <div class="container-custom">
        <div class="mb-6">
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white border-b border-gray-200 dark:border-gray-700 pb-2">Research Domains</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl">
          <div class="border border-gray-200 dark:border-gray-700 rounded-md p-5">
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-5 h-5 text-primary-600 dark:text-primary-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
              <h3 class="text-base font-semibold text-gray-900 dark:text-white">Computer Vision & AI</h3>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Developing intelligent systems for medical image analysis and automated diagnosis using state-of-the-art deep learning frameworks.
            </p>
          </div>

          <div class="border border-gray-200 dark:border-gray-700 rounded-md p-5">
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-5 h-5 text-accent-600 dark:text-accent-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
              <h3 class="text-base font-semibold text-gray-900 dark:text-white">Biomedical Robotics</h3>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Designing sensor-integrated robotic devices for neuro-rehabilitation to improve the quality of life for patients with motor impairments.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  // Toggle functionality for journal publications
  const toggleJournalsBtn = document.getElementById('toggle-journals-btn');
  const hiddenJournals = document.getElementById('hidden-journals');
  const journalsBtnText = document.getElementById('journals-btn-text');
  const journalsChevron = document.getElementById('journals-chevron');

  let journalsExpanded = false;

  toggleJournalsBtn?.addEventListener('click', () => {
    if (journalsExpanded) {
      hiddenJournals?.classList.add('hidden');
      journalsBtnText!.textContent = 'Show All Publications';
      journalsChevron?.classList.remove('rotate-180');
    } else {
      hiddenJournals?.classList.remove('hidden');
      journalsBtnText!.textContent = 'Show Less';
      journalsChevron?.classList.add('rotate-180');
    }
    journalsExpanded = !journalsExpanded;
  });

  // Toggle functionality for conference publications
  const toggleConferencesBtn = document.getElementById('toggle-conferences-btn');
  const hiddenConferences = document.getElementById('hidden-conferences');
  const conferencesBtnText = document.getElementById('conferences-btn-text');
  const conferencesChevron = document.getElementById('conferences-chevron');

  let conferencesExpanded = false;

  toggleConferencesBtn?.addEventListener('click', () => {
    if (conferencesExpanded) {
      hiddenConferences?.classList.add('hidden');
      conferencesBtnText!.textContent = 'View All Conference Items';
      conferencesChevron?.classList.remove('rotate-180');
    } else {
      hiddenConferences?.classList.remove('hidden');
      conferencesBtnText!.textContent = 'Show Less';
      conferencesChevron?.classList.add('rotate-180');
    }
    conferencesExpanded = !conferencesExpanded;
  });
</script>
