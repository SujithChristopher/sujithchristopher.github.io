---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout
  title="Research & Publications - Sujith Christopher | Computer Vision & Biomedical Robotics"
  description="Explore Sujith Christopher's research in computer vision, AI, sensors, and biomedical robotics. Discover his publications, conference presentations, and contributions to bioengineering and neuro-rehabilitation technology at IIT Madras."
  keywords="Sujith Christopher research, computer vision research, biomedical robotics, AI research, sensors research, IIT Madras research, bioengineering publications, neuro-rehabilitation technology, research publications"
>
  <Header />

  <main>
    <!-- Page Header -->
    <section class="pt-24 pb-4">
      <div class="container-custom">
        <div class="max-w-3xl">
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-1">
            Research & Publications
          </h1>
          <p class="text-sm text-gray-500 dark:text-gray-400">
            Computer Vision · Biomedical Robotics · Neuro-Rehabilitation
          </p>
        </div>
      </div>
    </section>

    <!-- Journal Publications -->
    <section class="section-padding">
      <div class="container-custom">
        <div class="max-w-5xl mx-auto">
          <div class="flex flex-col md:flex-row md:items-end justify-between mb-6 gap-2 border-b border-gray-200 dark:border-gray-800 pb-4">
            <div>
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white">
                Journal Publications
              </h2>
              <p class="text-gray-500 dark:text-gray-400 text-sm mt-0.5">Peer Reviewed Articles (6)</p>
            </div>
          </div>

          <div id="journal-publications" class="divide-y divide-gray-100 dark:divide-gray-800">
            <!-- Journal Publication 6 - 2020 -->
            <div class="pub-row">
              <div class="flex items-baseline gap-4">
                <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">2020</span>
                <div>
                  <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                    Dosimetric and Clinical Advantages of Adapting the DIBH Technique to Hybrid Solitary Dynamic Portal Radiotherapy for Left-sided Chest-wall plus Regional Nodal Irradiation
                  </p>
                  <p class="text-sm text-gray-600 dark:text-gray-400">
                    Mohamathu Rafic, Patricia Solomon, Timothy Peace Balasingh Santosh,
                    <span class="text-gray-900 dark:text-white font-bold underline decoration-primary-500/50">Sujith Christopher</span>, Selva Mani, Paul Ravindran
                  </p>
                  <p class="text-xs text-gray-500 dark:text-gray-500 italic mt-0.5">Medical Dosimetry · Vol. 45, Issue 3, pp. 256–263</p>
                </div>
              </div>
            </div>

            <!-- Journal Publication 5 - 2020 -->
            <div class="pub-row">
              <div class="flex items-baseline gap-4">
                <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">2020</span>
                <div>
                  <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                    A new strategy for craniospinal axis localization and adaptive dosimetric verification using cone beam CT
                  </p>
                  <p class="text-sm text-gray-600 dark:text-gray-400">
                    Mohamathu Rafic,
                    <span class="text-gray-900 dark:text-white font-bold underline decoration-primary-500/50">Sujith Christopher</span>,
                    Rajesh Balakrishnan, Ebenezer Suman Babu, Timothy Peace Balasingh Santosh
                  </p>
                  <p class="text-xs text-gray-500 dark:text-gray-500 italic mt-0.5">Reports of Practical Oncology & Radiotherapy · 25(2), 282–292</p>
                </div>
              </div>
            </div>

            <!-- Hidden journals container -->
            <div id="hidden-journals" class="hidden divide-y divide-gray-100 dark:divide-gray-800">
              <!-- Journal Publication 4 - 2019 -->
              <div class="pub-row">
                <div class="flex items-baseline gap-4">
                  <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">2019</span>
                  <div>
                    <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                      Escalation of optical transmittance and determination of diffusion co-efficient in low-bloom strength gelatin-based Fricke gel dosimeters
                    </p>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                      Ebenezer Suman Babu, Timothy Peace Balasingh Santosh, Winfred MR, Rafic KM,
                      <span class="text-gray-900 dark:text-white font-bold underline decoration-primary-500/50">Sujith Christopher</span>, Ravindran BP
                    </p>
                    <p class="text-xs text-gray-500 dark:text-gray-500 italic mt-0.5">Radiation Physics and Chemistry · 156, 300–306</p>
                  </div>
                </div>
              </div>

              <!-- Journal Publication 3 -->
              <div class="pub-row">
                <div class="flex items-baseline gap-4">
                  <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">2019</span>
                  <div>
                    <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                      A new strategy to determine off-axis dosimetric leaf gap using optically stimulated luminescence dosimeters and an electronic portal imaging device
                    </p>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                      Divyalakshmi, Timothy Peace Balasingh Santosh, KM Rafic, Amalan Sebastin, Jose Solomon,
                      <span class="text-gray-900 dark:text-white font-bold underline decoration-primary-500/50">Sujith Christopher</span>
                    </p>
                  </div>
                </div>
              </div>

              <!-- Journal Publication 2 -->
              <div class="pub-row">
                <div class="flex items-baseline gap-4">
                  <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">2018</span>
                  <div>
                    <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                      Planar and Volumetric Imaging Dosimetry for Longitudinal Projection Extended Cone Beam CT based Adaptive Radiotherapy
                    </p>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                      K Mohamathu Rafic, Ebenezer Suman Babu, S Timothy Peace Balasingh,
                      <span class="text-gray-900 dark:text-white font-bold underline decoration-primary-500/50">Sujith Christopher J</span>, Abel Juhan Thomas, B Paul Ravindran
                    </p>
                  </div>
                </div>
              </div>

              <!-- Journal Publication 1 -->
              <div class="pub-row">
                <div class="flex items-baseline gap-4">
                  <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">2018</span>
                  <div>
                    <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                      A survey on intelligence based biometric techniques for authentication applications
                    </p>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                      Martin Sagayam, Felix Jacob,
                      <span class="text-gray-900 dark:text-white font-bold underline decoration-primary-500/50">Sujith Christopher</span>, Santhosh A Immanuel, Vamsidhar Reddy
                    </p>
                    <p class="text-xs text-gray-500 dark:text-gray-500 italic mt-0.5">Lecture Notes in Computational Vision and Biomechanics (Vol. 25)</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Show More Button -->
            <div class="pt-3">
              <button
                id="toggle-journals-btn"
                class="text-sm text-primary-600 dark:text-primary-400 hover:underline"
              >
                <span id="journals-btn-text">Show All Publications</span>
                <svg id="journals-chevron" class="w-4 h-4 ml-1 transition-transform duration-300 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Conference Publications & Awards -->
    <section class="section-padding bg-gray-50 dark:bg-gray-900/50">
      <div class="container-custom">
        <div class="max-w-5xl mx-auto">
          <div class="flex flex-col md:flex-row md:items-end justify-between mb-6 gap-2 border-b border-gray-200 dark:border-gray-800 pb-4">
            <div>
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white">
                Conferences & Awards
              </h2>
              <p class="text-gray-500 dark:text-gray-400 text-sm mt-0.5">Presentations & Recognitions (7)</p>
            </div>
          </div>

          <div id="conference-publications" class="divide-y divide-gray-100 dark:divide-gray-800">
            <!-- Conference Award - Best Paper -->
            <div class="pub-row">
              <div class="flex items-baseline gap-4">
                <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">2022</span>
                <div>
                  <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                    <span class="text-xs font-semibold text-amber-700 dark:text-amber-400 mr-1">Best Paper Award —</span>Design and Development Of 3D Printed Paediatric Phantom for Evaluating the Accuracy of Deformable Image Registration Technique and Patient Specific QA
                  </p>
                  <p class="text-sm text-gray-600 dark:text-gray-400">
                    <span class="text-gray-900 dark:text-white font-bold underline decoration-accent-500/50">Sujith Christopher</span>, Timothy Peace Balasingh Santosh, Rafiq KM, Kavin
                  </p>
                  <p class="text-xs text-gray-500 dark:text-gray-500 italic mt-0.5">Prof. T. N. B. NEDUNGADI Best Paper Award, TN & PY AMPICON 2022</p>
                </div>
              </div>
            </div>

            <!-- Conference Item -->
            <div class="pub-row">
              <div class="flex items-baseline gap-4">
                <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">2022</span>
                <div>
                  <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                    Gamified upper limb therapy using an instrumented arm skateboard (ArmBo) and the YOLO framework
                  </p>
                  <p class="text-sm text-gray-600 dark:text-gray-400">
                    <span class="text-gray-900 dark:text-white font-bold underline decoration-primary-500/50">Sujith Christopher J</span>, Samuel Elias, Prem Kumar, Sivakumar Balasubramanian
                  </p>
                  <p class="text-xs text-gray-500 dark:text-gray-500 italic mt-0.5">Annual Research Day 2022, CMC Vellore (Poster)</p>
                </div>
              </div>
            </div>

            <!-- Conference Item 5 -->
            <div class="pub-row">
              <div class="flex items-baseline gap-4">
                <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">2022</span>
                <div>
                  <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                    Realtime feedback using an instrumented arm skateboard for upper-limb rehabilitation
                  </p>
                  <p class="text-sm text-gray-600 dark:text-gray-400">
                    <span class="text-gray-900 dark:text-white font-bold underline decoration-primary-500/50">Sujith Christopher J</span>, Sivakumar Balasubramanian
                  </p>
                  <p class="text-xs text-gray-500 dark:text-gray-500 italic mt-0.5">Annual Research Day 2022, CMC Vellore (Poster)</p>
                </div>
              </div>
            </div>

            <div id="hidden-conferences" class="hidden divide-y divide-gray-100 dark:divide-gray-800">
              <!-- Conference Publication 4 - 2022 -->
              <div class="pub-row">
                <div class="flex items-baseline gap-4">
                  <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">2022</span>
                  <div>
                    <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                      Investigation on sensor fusion-based feedback in arm-skateboard for upper-limb rehabilitation
                    </p>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                      <span class="text-gray-900 dark:text-white font-bold underline decoration-primary-500/50">Sujith Christopher J</span>, Sivakumar Balasubramanian
                    </p>
                    <p class="text-xs text-gray-500 dark:text-gray-500 italic mt-0.5">Empower 2022, IIT-M (Poster)</p>
                  </div>
                </div>
              </div>

              <!-- Conference Publication 3 - 2020 -->
              <div class="pub-row">
                <div class="flex items-baseline gap-4">
                  <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">2020</span>
                  <div>
                    <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                      Dynamic HU mapping and deformable image registration algorithm for adaptive treatment planning and dose calculation using neural network
                    </p>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                      <span class="text-gray-900 dark:text-white font-bold underline decoration-primary-500/50">Sujith Christopher J</span>, Timothy Peace Balasingh Santosh, Rafic KM, Paul Ravindran
                    </p>
                    <p class="text-xs text-gray-500 dark:text-gray-500 italic mt-0.5">Joint AAPM/COMP Virtual Meeting, 2020 (E-Poster)</p>
                  </div>
                </div>
              </div>

              <!-- Conference Publication 2 -->
              <div class="pub-row">
                <div class="flex items-baseline gap-4">
                  <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">2019</span>
                  <div>
                    <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                      Respiratory phantom for patient specific quality assurance of 4D gated radiation therapy
                    </p>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                      <span class="text-gray-900 dark:text-white font-bold underline decoration-primary-500/50">Sujith Christopher</span>, Timothy Peace Balasingh Santosh, Paul Ravindran
                    </p>
                  </div>
                </div>
              </div>

              <!-- First Prize Item -->
              <div class="pub-row">
                <div class="flex items-baseline gap-4">
                  <span class="text-xs text-gray-400 dark:text-gray-500 font-mono w-10 shrink-0">2019</span>
                  <div>
                    <p class="text-sm font-semibold text-gray-900 dark:text-white leading-snug mb-0.5">
                      <span class="text-xs font-semibold text-amber-700 dark:text-amber-400 mr-1">First Prize —</span>Wireless robotic phantom for quality assurance of 4D gated radiation therapy
                    </p>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                      <span class="text-gray-900 dark:text-white font-bold underline decoration-yellow-500/50">Sujith Christopher</span>, Paul Ravindran
                    </p>
                    <p class="text-xs text-gray-500 dark:text-gray-500 italic mt-0.5">9th Annual Research Day, CMC Vellore — First prize in Bioengineering category</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Show More Button -->
            <div class="pt-3">
              <button
                id="toggle-conferences-btn"
                class="text-sm text-primary-600 dark:text-primary-400 hover:underline"
              >
                <span id="conferences-btn-text">View All Conference Items</span>
                <svg id="conferences-chevron" class="w-4 h-4 ml-1 transition-transform duration-300 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Research Domains -->
    <section class="section-padding">
      <div class="container-custom">
        <div class="mb-6">
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white border-b border-gray-200 dark:border-gray-700 pb-2">Research Domains</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl">
          <div class="border border-gray-200 dark:border-gray-700 rounded-md p-5">
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-5 h-5 text-primary-600 dark:text-primary-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
              <h3 class="text-base font-semibold text-gray-900 dark:text-white">Computer Vision & AI</h3>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Developing intelligent systems for medical image analysis and automated diagnosis using state-of-the-art deep learning frameworks.
            </p>
          </div>

          <div class="border border-gray-200 dark:border-gray-700 rounded-md p-5">
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-5 h-5 text-accent-600 dark:text-accent-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
              <h3 class="text-base font-semibold text-gray-900 dark:text-white">Biomedical Robotics</h3>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Designing sensor-integrated robotic devices for neuro-rehabilitation to improve the quality of life for patients with motor impairments.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  // Toggle functionality for journal publications
  const toggleJournalsBtn = document.getElementById('toggle-journals-btn');
  const hiddenJournals = document.getElementById('hidden-journals');
  const journalsBtnText = document.getElementById('journals-btn-text');
  const journalsChevron = document.getElementById('journals-chevron');

  let journalsExpanded = false;

  toggleJournalsBtn?.addEventListener('click', () => {
    if (journalsExpanded) {
      hiddenJournals?.classList.add('hidden');
      journalsBtnText!.textContent = 'Show All Publications';
      journalsChevron?.classList.remove('rotate-180');
    } else {
      hiddenJournals?.classList.remove('hidden');
      journalsBtnText!.textContent = 'Show Less';
      journalsChevron?.classList.add('rotate-180');
    }
    journalsExpanded = !journalsExpanded;
  });

  // Toggle functionality for conference publications
  const toggleConferencesBtn = document.getElementById('toggle-conferences-btn');
  const hiddenConferences = document.getElementById('hidden-conferences');
  const conferencesBtnText = document.getElementById('conferences-btn-text');
  const conferencesChevron = document.getElementById('conferences-chevron');

  let conferencesExpanded = false;

  toggleConferencesBtn?.addEventListener('click', () => {
    if (conferencesExpanded) {
      hiddenConferences?.classList.add('hidden');
      conferencesBtnText!.textContent = 'View All Conference Items';
      conferencesChevron?.classList.remove('rotate-180');
    } else {
      hiddenConferences?.classList.remove('hidden');
      conferencesBtnText!.textContent = 'Show Less';
      conferencesChevron?.classList.add('rotate-180');
    }
    conferencesExpanded = !conferencesExpanded;
  });
</script>
