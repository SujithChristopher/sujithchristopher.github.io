---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

// ─── DATA ────────────────────────────────────────────────────────────────────

type Position = {
  title: string;
  dateRange: string;
  org: string;
  isCurrent?: boolean;
  tags?: string[];
};

type Degree = {
  name: string;
  dateRange: string;
  institution: string;
};

const experience: Position[] = [
  {
    title: 'Project Research Scientist',
    dateRange: 'Mar 2025 - Present',
    org: 'IIT Madras, Dept. of Mechanical Engineering',
    isCurrent: true,
    tags: ['Neuro-Rehab', 'Robotics'],
  },
  {
    title: 'Project Associate',
    dateRange: 'Oct 2023 - Feb 2025',
    org: 'IIT Madras, Dept. of Mechanical Engineering',
  },
  {
    title: 'Postgraduate Trainee',
    dateRange: 'Oct 2021 - Oct 2023',
    org: 'CMC Vellore, Dept. of Bioengineering',
  },
  {
    title: 'Project Associate',
    dateRange: 'Mar 2021 - Sep 2021',
    org: 'IIT Madras, Dept. of Applied Mechanics',
  },
  {
    title: 'Senior Research Fellow',
    dateRange: 'Aug 2019 - Aug 2020',
    org: 'CMC Vellore, Dept. of Radiation Oncology',
  },
];

const education: Degree[] = [
  {
    name: 'M.S. in Bioengineering',
    dateRange: '2021 — 2023',
    institution: 'Joint degree program by CMC Vellore & SCTIMST Trivandrum',
  },
  {
    name: 'B.Tech in Electronics',
    dateRange: '2013 — 2017',
    institution: 'Karunya Institute of Technology and Sciences, Coimbatore',
  },
];

const EXPERIENCE_INITIAL = 3;
const currentRole = experience.find(e => e.isCurrent)!;

// ─── END DATA ─────────────────────────────────────────────────────────────────
---

<Layout
  title="Sujith Christopher - Project Research Scientist | Bioengineering & AI Researcher"
  description="Sujith Christopher is a Project Research Scientist at IIT Madras specializing in bioengineering, neuro-rehabilitation technology, computer vision, AI, sensors, and biomedical robotics. Explore his research, publications, and professional journey."
  keywords="Sujith Christopher, Project Research Scientist, IIT Madras, bioengineering, neuro-rehabilitation, computer vision, artificial intelligence, sensors, biomedical robotics, research scientist, CMC Vellore, SCTIMST"
>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="pt-20 pb-8 lg:pt-28 lg:pb-10">
      <div class="container-custom">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
          <!-- Hero Content -->
          <div class="lg:col-span-7 order-2 lg:order-1">
            <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-1 leading-tight">
              Sujith Christopher
            </h1>
            <p class="text-base text-primary-600 dark:text-primary-400 font-medium mb-3">
              {currentRole.title}, IIT Madras
            </p>
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-6 max-w-lg leading-relaxed">
              Bridging <span class="font-medium text-gray-800 dark:text-gray-200">Bioengineering</span> and <span class="font-medium text-gray-800 dark:text-gray-200">AI</span> to create innovative neuro-rehabilitation technologies.
            </p>

            <div class="flex flex-wrap gap-3">
              <a href="/research" class="btn-primary">
                Explore Research
              </a>
              <a href="/news" class="btn-secondary">
                Latest Updates
              </a>
            </div>
          </div>

          <!-- Profile Image -->
          <div class="lg:col-span-5 flex justify-center lg:justify-end order-1 lg:order-2">
            <div class="w-48 h-48 md:w-64 md:h-64 rounded-full overflow-hidden border-2 border-gray-200 dark:border-gray-700">
              <img
                src="/Sujith.jpg"
                alt="Sujith Christopher"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Affiliations -->
    <section class="py-4 border-b border-gray-100 dark:border-gray-800 bg-gray-50/50 dark:bg-gray-900/20">
      <div class="container-custom">
        <div class="flex flex-wrap justify-start items-center gap-6 md:gap-12">
          <span class="text-sm font-semibold text-gray-400 dark:text-gray-500 tracking-tighter">IIT MADRAS</span>
          <span class="text-sm font-semibold text-gray-400 dark:text-gray-500 tracking-tighter">CMC VELLORE</span>
          <span class="text-sm font-semibold text-gray-400 dark:text-gray-500 tracking-tighter">SCTIMST</span>
          <span class="text-sm font-semibold text-gray-400 dark:text-gray-500 tracking-tighter">KARUNYA</span>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section class="section-padding overflow-hidden">
      <div class="container-custom">
        <div class="max-w-4xl mx-auto">
          <div class="mb-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white border-b border-gray-200 dark:border-gray-700 pb-2">About</h2>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Education -->
            <div class="card">
              <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-3">Education</h3>

              <div class="space-y-4">
                {education.map(deg => (
                  <div class="relative pl-6 border-l-2 border-primary-200 dark:border-primary-800 group-hover:border-primary-500 transition-colors">
                    <h4 class="text-base font-bold text-gray-900 dark:text-white mb-1">{deg.name}</h4>
                    <p class="text-primary-600 dark:text-primary-400 font-semibold text-xs mb-1">{deg.dateRange}</p>
                    <p class="text-gray-600 dark:text-gray-400 text-xs leading-relaxed">{deg.institution}</p>
                  </div>
                ))}
              </div>
            </div>

            <!-- Current Position -->
            <div class="card">
              <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-3">Current Role</h3>

              <div class="relative pl-6 border-l-2 border-accent-200 dark:border-accent-800 group-hover:border-accent-500 transition-colors">
                <h4 class="text-base font-bold text-gray-900 dark:text-white mb-1">{currentRole.title}</h4>
                <p class="text-accent-600 dark:text-accent-400 font-semibold text-xs mb-1">Mar 2025 — Present</p>
                <p class="text-gray-600 dark:text-gray-400 text-xs leading-relaxed mb-3">
                  Department of Mechanical Engineering<br/>
                  <span class="font-bold">Indian Institute of Technology (IIT) Madras</span>
                </p>
                {currentRole.tags && (
                  <div class="flex flex-wrap gap-2">
                    {currentRole.tags.map(tag => (
                      <span class="px-2 py-0.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-[9px] font-bold uppercase tracking-wider rounded-md">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Experience Timeline -->
    <section class="section-padding bg-gray-50 dark:bg-gray-900/50">
      <div class="container-custom">
        <div class="max-w-4xl mx-auto">
          <div class="mb-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white border-b border-gray-200 dark:border-gray-700 pb-2">Professional Journey</h2>
          </div>

          <div class="relative">
            <!-- Timeline line -->
            <div class="absolute left-10 md:left-1/2 top-0 bottom-0 w-1 bg-gradient-to-b from-primary-200 via-primary-500 to-accent-500 dark:from-primary-900 dark:via-primary-700 dark:to-accent-900 md:-translate-x-1/2 rounded-full opacity-30"></div>

            <div class="space-y-8 relative">
              {experience.slice(0, EXPERIENCE_INITIAL).map((pos, i) => (
                <div class="relative flex flex-col md:flex-row items-center">
                  <div class="absolute left-10 md:left-1/2 w-3 h-3 bg-white dark:bg-gray-950 border-2 border-gray-400 dark:border-gray-600 rounded-full md:-translate-x-1/2 z-10"></div>
                  <div class={i % 2 === 0
                    ? 'md:w-1/2 md:pr-12 ml-20 md:ml-0 md:text-right'
                    : 'md:w-1/2 md:pl-12 ml-20 md:ml-0 md:mr-auto'
                  }>
                    <div class="border border-gray-200 dark:border-gray-700 rounded-md p-3">
                      <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-0.5">{pos.title}</h3>
                      <p class={`${pos.isCurrent ? 'text-primary-600 dark:text-primary-400' : 'text-gray-500 dark:text-gray-400'} text-xs mb-1`}>{pos.dateRange}</p>
                      <p class="text-gray-600 dark:text-gray-400 text-xs">{pos.org}</p>
                    </div>
                  </div>
                </div>
              ))}

              <div id="hidden-positions" class="hidden space-y-8">
                {experience.slice(EXPERIENCE_INITIAL).map((pos, i) => (
                  <div class={`relative flex flex-col md:flex-row items-center${i === 0 ? ' pt-8' : ''}`}>
                    <div class="absolute left-10 md:left-1/2 w-3 h-3 bg-white dark:bg-gray-950 border-2 border-gray-400 dark:border-gray-600 rounded-full md:-translate-x-1/2 z-10"></div>
                    <div class={(EXPERIENCE_INITIAL + i) % 2 === 0
                      ? 'md:w-1/2 md:pr-12 ml-20 md:ml-0 md:text-right'
                      : 'md:w-1/2 md:pl-12 ml-20 md:ml-0 md:mr-auto'
                    }>
                      <div class="border border-gray-200 dark:border-gray-700 rounded-md p-3">
                        <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-0.5">{pos.title}</h3>
                        <p class="text-gray-500 dark:text-gray-400 text-xs mb-1">{pos.dateRange}</p>
                        <p class="text-gray-600 dark:text-gray-400 text-xs">{pos.org}</p>
                      </div>
                    </div>
                  </div>
                ))}
              </div>

              <!-- Show More Button -->
              <div class="text-center pt-4">
                <button
                  id="toggle-positions-btn"
                  class="btn-secondary group !py-2 !px-6 !text-sm"
                >
                  <span id="positions-btn-text">Explore Full Journey</span>
                  <svg id="positions-chevron" class="w-4 h-4 ml-2 transition-transform duration-500 inline-block group-hover:translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Research Areas -->
    <section class="section-padding">
      <div class="container-custom">
        <div class="mb-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white border-b border-gray-200 dark:border-gray-700 pb-2">Research Domains</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-4xl">
          <div class="border border-gray-200 dark:border-gray-700 rounded-md p-5">
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-5 h-5 text-primary-600 dark:text-primary-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
              <h3 class="text-base font-semibold text-gray-900 dark:text-white">Computer Vision & AI</h3>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Developing intelligent systems for medical image analysis and automated diagnosis using state-of-the-art deep learning frameworks.
            </p>
          </div>

          <div class="border border-gray-200 dark:border-gray-700 rounded-md p-5">
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-5 h-5 text-accent-600 dark:text-accent-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
              <h3 class="text-base font-semibold text-gray-900 dark:text-white">Biomedical Robotics</h3>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              Designing sensor-integrated robotic devices for neuro-rehabilitation to improve the quality of life for patients with motor impairments.
            </p>
          </div>
        </div>

        <div class="text-center mt-12">
          <a href="/research" class="inline-flex items-center text-primary-600 dark:text-primary-400 font-bold text-sm hover:underline group">
            View Research Publications
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtn = document.getElementById('toggle-positions-btn');
    const hiddenPositions = document.getElementById('hidden-positions');
    const btnText = document.getElementById('positions-btn-text');
    const chevron = document.getElementById('positions-chevron');

    let isExpanded = false;

    toggleBtn?.addEventListener('click', () => {
      isExpanded = !isExpanded;

      if (isExpanded) {
        hiddenPositions?.classList.remove('hidden');
        if (btnText) btnText.textContent = 'Show Less Positions';
        chevron?.classList.add('rotate-180');
      } else {
        hiddenPositions?.classList.add('hidden');
        if (btnText) btnText.textContent = 'Show More Positions';
        chevron?.classList.remove('rotate-180');
      }
    });
  });
</script>
