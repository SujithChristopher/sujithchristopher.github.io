---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout 
  title="News & Updates - Sujith Christopher | Latest Research & Professional Achievements"
  description="Stay updated with Sujith Christopher's latest research developments, professional achievements, conferences, and news in bioengineering, computer vision, AI, and biomedical robotics at IIT Madras."
  keywords="Sujith Christopher news, research updates, bioengineering news, computer vision developments, AI research updates, IIT Madras news, professional achievements, conference presentations, research milestones"
>
  <Header />
  
  <main>
    <!-- Page Header -->
    <section class="pt-24 pb-4">
      <div class="container-custom">
        <div class="max-w-3xl">
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-1">
            News & Updates
          </h1>
          <p class="text-sm text-gray-500 dark:text-gray-400">
            Research milestones, academic recognitions, and professional activities.
          </p>
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="section-padding">
      <div class="container-custom">
        <div class="max-w-5xl mx-auto">
          <div class="relative">
            <!-- Timeline Line -->
            <div class="absolute left-8 md:left-1/2 md:transform md:-translate-x-px top-0 bottom-0 w-1 bg-gradient-to-b from-primary-200 via-primary-500 to-accent-500 dark:from-primary-900 dark:via-primary-700 dark:to-accent-900 rounded-full opacity-20"></div>
            
            <div class="space-y-10 relative">
              <!-- News Item 1 - Feb 2024 -->
              <div class="relative flex flex-col md:flex-row items-start md:items-center">
                <div class="absolute left-8 md:left-1/2 md:transform md:-translate-x-1/2 w-3 h-3 bg-white dark:bg-gray-950 border-2 border-gray-400 dark:border-gray-600 rounded-full z-10"></div>

                <div class="ml-20 md:ml-0 md:w-1/2 md:pr-16 md:text-right">
                  <div class="border border-gray-200 dark:border-gray-700 rounded-md p-4">
                    <p class="text-xs text-gray-400 dark:text-gray-500 font-mono mb-1">Feb 2024</p>
                    <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-2">
                      RV-PHYSIOCON Workshop
                    </h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400 mb-3 leading-relaxed">
                      Conducted an interactive workshop on RV-PHYSIOCON in Bangalore with <a href="https://biorehab.github.io/" target="_blank" class="text-primary-600 font-semibold hover:underline">@BioRehabGroup</a>. Showcased advancements in NeuroRehabilitation technology and computer vision.
                    </p>
                    <div class="aspect-video rounded overflow-hidden bg-gray-100 dark:bg-gray-800">
                      <iframe
                        src="https://www.youtube.com/embed/hF_kUx-l4uM"
                        title="RV-PHYSIOCON Workshop"
                        class="w-full h-full"
                        style="border: none;"
                        allowfullscreen
                      ></iframe>
                    </div>
                  </div>
                </div>
              </div>

              <!-- News Item 2 - Nov 2023 -->
              <div class="relative flex flex-col md:flex-row items-start md:items-center">
                <div class="absolute left-8 md:left-1/2 md:transform md:-translate-x-1/2 w-3 h-3 bg-white dark:bg-gray-950 border-2 border-gray-400 dark:border-gray-600 rounded-full z-10"></div>

                <div class="ml-20 md:ml-0 md:w-1/2 md:pl-16 md:mr-auto">
                  <div class="border border-gray-200 dark:border-gray-700 rounded-md p-4">
                    <p class="text-xs text-gray-400 dark:text-gray-500 font-mono mb-1">Nov 2023</p>
                    <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-2">
                      ReHackathon, India'23
                    </h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400 mb-3 leading-relaxed">
                      Organized a major hackathon on neuro-rehab engineering at CMC Vellore. Great opportunity to mentor students and explore innovative project ideas.
                    </p>
                    <div class="aspect-video rounded overflow-hidden bg-gray-100 dark:bg-gray-800">
                      <iframe
                        src="https://www.youtube.com/embed/ZPAHwwmDY2A"
                        title="ReHackathon India 2023"
                        class="w-full h-full"
                        style="border: none;"
                        allowfullscreen
                      ></iframe>
                    </div>
                  </div>
                </div>
              </div>

              <!-- News Item 3 - Oct 2023 -->
              <div class="relative flex flex-col md:flex-row items-start md:items-center">
                <div class="absolute left-8 md:left-1/2 md:transform md:-translate-x-1/2 w-3 h-3 bg-white dark:bg-gray-950 border-2 border-gray-400 dark:border-gray-600 rounded-full z-10"></div>

                <div class="ml-20 md:ml-0 md:w-1/2 md:pr-16 md:text-right">
                  <div class="border border-gray-200 dark:border-gray-700 rounded-md p-4">
                    <p class="text-xs text-gray-400 dark:text-gray-500 font-mono mb-1">Oct 2023</p>
                    <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-2">
                      <span class="text-xs font-semibold text-amber-700 dark:text-amber-400 mr-1">Silver Medal —</span>CMC Research Day
                    </h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
                      Awarded the Silver Medal at CMC Annual Research Day'23 for outstanding contribution to Bioengineering research.
                    </p>
                  </div>
                </div>
              </div>

              <!-- News Item 4 - Dec 2022 -->
              <div class="relative flex flex-col md:flex-row items-start md:items-center">
                <div class="absolute left-8 md:left-1/2 md:transform md:-translate-x-1/2 w-3 h-3 bg-white dark:bg-gray-950 border-2 border-gray-400 dark:border-gray-600 rounded-full z-10"></div>

                <div class="ml-20 md:ml-0 md:w-1/2 md:pl-16 md:mr-auto">
                  <div class="border border-gray-200 dark:border-gray-700 rounded-md p-4">
                    <p class="text-xs text-gray-400 dark:text-gray-500 font-mono mb-1">Dec 2022</p>
                    <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-2">
                      <span class="text-xs font-semibold text-amber-700 dark:text-amber-400 mr-1">Best Paper Award —</span>TN-AMPICON
                    </h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
                      Received the Prof. T. N. B. NEDUNGADI Best Paper Award for work on 3D Printed Pediatric Phantoms and Deformable Image Registration.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Professional Profiles -->
    <section class="section-padding border-t border-gray-100 dark:border-gray-800">
      <div class="container-custom">
        <div class="max-w-4xl">
          <div class="mb-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white border-b border-gray-200 dark:border-gray-700 pb-2">Profiles</h2>
          </div>
          <div class="divide-y divide-gray-100 dark:divide-gray-800">
            <a href="https://github.com/SujithChristopher" target="_blank" class="flex items-center gap-3 py-3 text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
              <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              <span class="font-medium text-gray-900 dark:text-white">GitHub</span>
              <span class="text-gray-400 dark:text-gray-500">— Open Source Projects</span>
            </a>
            <a href="https://www.researchgate.net/profile/Sujith-Christopher" target="_blank" class="flex items-center gap-3 py-3 text-sm text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
              <svg class="w-5 h-5 shrink-0 text-emerald-500" fill="currentColor" viewBox="0 0 24 24"><path d="M19.586 0c-.818 0-1.508.19-2.073.565-.563.377-.87.994-.92 1.846-.051.851.178 1.66.685 2.42l3.219 4.815c.507.761.761 1.658.761 2.688 0 1.029-.254 1.927-.761 2.688l-3.219 4.815c-.507.76-.736 1.569-.685 2.42.05.852.357 1.469.92 1.846.565.375 1.255.565 2.073.565.818 0 1.508-.19 2.073-.565.563-.377.87-.994.92-1.846.051-.851-.178-1.66-.685-2.42l-3.219-4.815c-.507-.761-.761-1.658-.761-2.688 0-1.029.254-1.927.761-2.688l3.219-4.815c.507-.76.736-1.569.685-2.42-.05-.852-.357-1.469-.92-1.846C21.094.19 20.404 0 19.586 0z"/></svg>
              <span class="font-medium text-gray-900 dark:text-white">ResearchGate</span>
              <span class="text-gray-400 dark:text-gray-500">— Scientific Publications</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

